    <property name="styleSheet">
     <string notr="true">QComboBox{
	background:transparent;
   	font-family: HarmonyOS Sans SC;
    font:bold 20px;
	color:black;
	border:none;
}

QComboBox::drop-down {	
	border-style:none;
	subcontrol-origin: padding;
	subcontrol-position: center right; /* 位置 */
	width: 46px; /* 宽度 */
	/* 其他样式 */
}

QComboBox::down-arrow{
	image: url(:/icon/PNG/icon_selectable.png); /* 图标 */
	width: 16px; /* 宽度 */
	height:16px
	/* 其他样式 */
}

QComboBox::down-arrow:hover{
	image: url(:/icon/PNG/icon_selectable.png); /* 图标 */
	width: 20px; /* 宽度 */
	height:20px
	/* 其他样式 */
}

QComboBox::down-arrow:pressed{
	image: url(:/icon/PNG/icon_selectable_pressed.png); /* 图标 */
	width: 20px; /* 宽度 */
	height:20px
	/* 其他样式 */
}

QComboBox QAbstractItemView{
	outline: 0px; /* 去掉虚线 */
	border-radius:0px;
	background-color: rgb(237, 242, 255); /* 背景颜色 */
   	font-family: HarmonyOS Sans SC;
	font:18px;
}

QComboBox QAbstractItemView:item {
	height: 40px; /* 项高度 */
	/* 其他样式 */
   	font-family: HarmonyOS Sans SC;
    font:bold 22px;
}

QComboBox QAbstractItemView::item:hover {
	color:#FFFFFF;
	background-color: rgb(24, 82, 154); /* 悬浮背景色 */
	/* 其他样式 */
}

QComboBox QAbstractItemView::item:selected {
	color:#FFFFFF;
	background-color: rgb(24, 82, 154); /* 选中背景色 */
	/* 其他样式 */
}</string>
